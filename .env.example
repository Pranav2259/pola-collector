# ── pola binary ──────────────────────────────────────────────────────────────
# Path to the pola CLI binary
POLA_BINARY=./pola

# gRPC port pola PCE is listening on
POLA_PORT=50052

# gRPC host (leave blank for localhost / whatever pola defaults to)
POLA_HOST=

# ── postgres ─────────────────────────────────────────────────────────────────
# Full libpq-style DSN
POSTGRES_DSN=host=localhost port=5432 user=pola password=pola dbname=pola sslmode=disable

# ── timing ───────────────────────────────────────────────────────────────────
# How often to run both pola commands. Go duration string: 30s, 1m, 5m, 1h …
COLLECT_INTERVAL=1m

# How many times to retry the initial DB connection before giving up
DB_CONN_RETRIES=5

# How long to wait between connection retries
DB_CONN_DELAY=3s
